{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "checkJs": false,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "es2020"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noEmitHelpers": true,
    "noImplicitReturns": true,
    "outDir": "lib/",
    "pretty": true,
    "sourceMap": true,
    "strict": true,
    "baseUrl": ".",
    "target": "es2020"
  },
  "include": [
    "components/"
  ],
  "exclude": [
    "components/**/*.test.ts",
    "components/**/*.test.tsx"
  ]
}
