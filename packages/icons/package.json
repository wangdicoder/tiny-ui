{
  "name": "@tiny-design/icons",
  "version": "1.0.12",
  "description": "SVG icon components for tiny-design",
  "license": "MIT",
  "keywords": [
    "tiny",
    "tiny-design",
    "icons",
    "svg",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wangdicoder/tiny-design.git",
    "directory": "packages/icons"
  },
  "author": "Di Wang<wangdicoder@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "main": "lib/index.js",
  "module": "es/index.js",
  "typings": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./lib/*": "./lib/*",
    "./es/*": "./es/*"
  },
  "sideEffects": false,
  "files": [
    "lib",
    "es"
  ],
  "scripts": {
    "generate": "node scripts/generate-icons.js",
    "build": "npm run clean && npm run generate && tsdown",
    "clean": "rimraf lib es",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:update": "jest --updateSnapshot"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/react": "^18.2.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^3.0.2",
    "ts-jest": "^29.0.0",
    "tsdown": "^0.21.1",
    "typescript": "^5.4.0"
  }
}
