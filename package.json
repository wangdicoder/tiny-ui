{
  "name": "tiny-ui",
  "version": "1.0.4",
  "private": true,
  "description": "A friendly UI component set for React",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangdicoder/tiny-ui.git"
  },
  "author": "Di Wang<wangdicoder@gmail.com>",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:style": "turbo run lint:style",
    "prepare": "husky",
    "changelog": "node packages/react/scripts/changelog.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "commitlint-config-cz": "^0.13.3",
    "cz-customizable": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jest": "^28.0.0",
    "eslint-plugin-jest-dom": "^5.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "turbo": "^2.8.16",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "packages/react/src/**/*.scss": [
      "stylelint --fix"
    ]
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead",
    "not IE 11"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher"
    ]
  }
}
