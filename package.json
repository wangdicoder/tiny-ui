{
  "name": "tiny-ui",
  "version": "1.0.4",
  "description": "A friendly ui component set for react",
  "license": "MIT",
  "keywords": [
    "tiny",
    "tiny-ui",
    "design",
    "react",
    "react-component",
    "component",
    "components",
    "ui",
    "frontend",
    "react hook component",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wangdicoder/tiny-ui.git"
  },
  "author": "Di Wang<wangdicoder@gmail.com>",
  "homepage": "https://tiny-ui.dev/",
  "main": "lib/index.js",
  "module": "es/index.js",
  "typings": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./lib/*": "./lib/*",
    "./es/*": "./es/*"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "lib",
    "es"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run clean && tsdown && node scripts/build-styles.js && node scripts/inject-style-imports.js",
    "clean": "rimraf lib es",
    "dev": "vite serve site",
    "site:build": "vite build site",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:update": "jest --updateSnapshot",
    "lint": "eslint components/",
    "lint:style": "stylelint \"components/**/*.scss\"",
    "lint:style:fix": "npm run lint:style -- --fix",
    "changelog": "node scripts/changelog.js",
    "prepare": "husky"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.4",
    "classnames": "^2.3.1",
    "react-transition-group": "^4.4.2",
    "tslib": "^2.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-transition-group": "^4.4.4",
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.4",
    "commitlint-config-cz": "^0.13.3",
    "cz-customizable": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jest": "^28.0.0",
    "eslint-plugin-jest-dom": "^5.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-live": "^4.1.0",
    "react-router-dom": "^6.0.0",
    "rehype-mdx-code-props": "^3.0.1",
    "remark-gfm": "^4.0.1",
    "rimraf": "^3.0.2",
    "sass": "^1.49.9",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "ts-jest": "^29.0.0",
    "tsdown": "^0.21.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "components/**/*.scss": [
      "npm run lint:style:fix"
    ]
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead",
    "not IE 11"
  ]
}
